# Aurforge data dir
AURFORGE_DATA_ROOT=./data

# Local package directories are explicitly imported with:
# aurforge add --local <package-directory>
AURFORGE_LOCAL_IMPORT_ROOT=./local-pkgs

# PostgreSQL only. No database container is part of this deployment.
DATABASE_URL=postgres://<database-url>

# Optional: join an existing Docker network that already has Postgres so the DB
# does not need a published host port.
#AURFORGE_DATABASE_NETWORK=postgres
#AURFORGE_DATABASE_EXTERNAL=true

AURFORGE_IMAGE_TAG=latest
AURFORGE_BUILDER_IMAGE=aurforge-builder:latest
AURFORGE_LOG_LEVEL=info
AURFORGE_REPO_BIND=127.0.0.1
AURFORGE_REPO_PORT=8088
AURFORGE_REPOSITORY_NAME=aurforge
# How old an AUR commit must be before Aurforge builds it. Local imports ignore this.
AURFORGE_UPDATE_DELAY=12h
AURFORGE_POLL_INTERVAL=30m

# Leave blank to disable notifications. Aurforge sends ntfy only for failures.
AURFORGE_NTFY_URL=https://ntfy.example.net
AURFORGE_NTFY_TOPIC=aurforge-failures
AURFORGE_NTFY_TOKEN=

# Runtime-service resource limits.
AURFORGE_APP_CPU_LIMIT=1.0
AURFORGE_APP_CPU_SHARES=512
AURFORGE_APP_MEMORY_LIMIT=512m
AURFORGE_APP_PIDS_LIMIT=256
AURFORGE_REPO_CPU_LIMIT=0.5
AURFORGE_REPO_CPU_SHARES=256
AURFORGE_REPO_MEMORY_LIMIT=128m
AURFORGE_REPO_PIDS_LIMIT=64
AURFORGE_SHUTDOWN_TIMEOUT=30s

# Passed to the worker. Future job-launching code must apply these to each
# aurforge-builder container, not merely retain them as worker configuration.
# Accepts a Docker CPU value such as 6.4 or a percentage of the Docker host.
AURFORGE_BUILD_CPU_LIMIT=80%
AURFORGE_BUILD_CPU_SHARES=1024
AURFORGE_BUILD_MEMORY_LIMIT=2g
AURFORGE_BUILD_PIDS_LIMIT=512
AURFORGE_BUILD_TIMEOUT=60m
